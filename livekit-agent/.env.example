# LiveKit (from https://cloud.livekit.io)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=sag-face-agent

# OpenAI — TTS required; STT/LLM only when voice input is enabled
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TTS_VOICE=nova

# Output-only by default: avatar speaks via sag.speak (Telegram → House), not room mic.
# SAG_VOICE_INPUT_ENABLED=true

# Simli photoreal avatar (https://simli.com)
SIMLI_API_KEY=
SIMLI_FACE_ID=

# Simli session persistence (seconds)
SIMLI_MAX_IDLE_TIME=1800
SIMLI_MAX_SESSION_LENGTH=7200

# Bridge in-room voice to the full SAG worker (same brain as Telegram)
# SAG_WORKER_URL=http://127.0.0.1:9473
# TELEGRAM_CHAT_ID=          # same chat id as root .env — shared memory thread
# SAG_BRIDGE_ENABLED=true    # set false to use local LLM only
