# Copy to .env and fill in values as we complete each setup step.

# Worker
# POLL_INTERVAL_MS — how often Gmail email skills are polled when gmail-poll skill is enabled (default 10 min).
# Scheduled skills (focus, morning, heartbeat, dev-runner) run on SCHEDULE_CRON instead.
POLL_INTERVAL_MS=600000
# Cron pattern for scheduled skills (default: every minute).
# SCHEDULE_CRON=* * * * *
DRY_RUN=true
LOG_LEVEL=info

# Gmail (Google Cloud OAuth)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=me

# Telegram notifications (free)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Assistant (OpenAI-compatible API)
OPENAI_API_KEY=
# ASSISTANT_MODEL=gpt-4o-mini
# ASSISTANT_MAX_TOKENS=120          # default companion reply cap (voice-friendly)
# ASSISTANT_PLAN_MAX_TOKENS=280     # when Devin asks for a plan/steps/breakdown
# ASSISTANT_TEMPERATURE=0.85
# OPENAI_BASE_URL=https://api.openai.com/v1

# Mem0 memory (https://github.com/mem0ai/mem0)
# Default: local OSS store in data/mem0/ using OPENAI_API_KEY
MEM0_ENABLED=true
# MEM0_API_KEY=              # optional — use Mem0 Platform instead of local OSS
# MEM0_HOST=https://api.mem0.ai
# MEM0_LLM_MODEL=gpt-4o-mini
# MEM0_EMBED_MODEL=text-embedding-3-small
# SAG_USER_ID=               # optional override for memory user id (default: telegram chat id)
# CONVERSATION_MAX_MESSAGES=24

# Agent reflection (distills activity log into Mem0 agent memories)
REFLECTION_ENABLED=true
# REFLECTION_HOURS=13,21
# REFLECTION_TIMEZONE=America/New_York
# SAG_AGENT_ID=sag

# Heartbeat (optional overrides — defaults are daily)
# HEARTBEAT_REPORT_INTERVAL_MS=86400000
# HEARTBEAT_STALE_AFTER_MS=86400000
# HEARTBEAT_ALERT_COOLDOWN_MS=86400000

# Morning briefing (7:30 AM conversation starter)
MORNING_BRIEFING_ENABLED=true
MORNING_BRIEFING_TIME=07:30
MORNING_BRIEFING_TIMEZONE=America/New_York

# Focus companion (Phase 1: 3 LLM anchors at 8 AM, 1 PM, 9 PM)
FOCUS_COMPANION_ENABLED=true
FOCUS_TIMEZONE=America/New_York
FOCUS_ANCHOR_HOURS=8,13,21
FOCUS_ACTIVE_START_HOUR=8
FOCUS_ACTIVE_END_HOUR=21
FOCUS_HOURLY=false

# Life companion (random personal texts, separate from focus anchors)
LIFE_COMPANION_ENABLED=true
# LIFE_COMPANION_DAILY_CAP=5
# LIFE_COMPANION_MIN_GAP_MINUTES=90
# LIFE_COMPANION_WINDOW_START=8
# LIFE_COMPANION_WINDOW_END=22
# LIFE_COMPANION_SLOT_WINDOW_MINUTES=5

# Autonomous dev (Option D: orchestrator + Cursor Cloud)
DEV_RUNNER_ENABLED=false
# DEV_ORCHESTRATOR_MODE=cursor
# DEV_AUTO_MERGE=true
# DEV_POST_MERGE_AUDIT=true
# GITHUB_REPO=masond84/sag-agent
# LINEAR_API_KEY=
# LINEAR_TEAM_KEY=SAG
# LINEAR_PROJECT=SAG Agent
# CURSOR_API_KEY=
# DEV_CLOUD_MODEL=composer-2.5
# DEV_CLOUD_TIMEOUT_MS=1800000
# DEV_CLOUD_POLL_MS=15000
# DEV_AUDIT_INTERVAL_MS=21600000
# DEV_RUN_TIMEOUT_MS=1800000
# DEV_SELF_RESTART=true

# SAG House (optional local web UI — see house/README.md)
# HOUSE_SERVER_ENABLED=false
# HOUSE_SERVER_HOST=127.0.0.1
# HOUSE_SERVER_PORT=9473
# HOUSE_SPEECH_MAX_CHARS=320
