{
  "name": "sag",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted agent worker — skill runner with Conservice as first skill",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc",
    "worker": "tsx src/main.ts",
    "worker:once": "tsx src/main.ts --once",
    "test:conservice": "tsx src/scripts/test-conservice.ts",
    "test:morning": "tsx src/scripts/test-morning.ts",
    "test:heartbeat": "tsx src/scripts/test-heartbeat.ts",
    "test:focus": "tsx src/scripts/test-focus.ts",
    "test:life": "tsx src/scripts/test-life-companion.ts",
    "test:memory": "tsx src/scripts/test-memory.ts",
    "test:activity": "tsx src/scripts/test-activity-log.ts",
    "test:reflection": "tsx src/scripts/test-reflection.ts",
    "test:purge-agent-memories": "tsx src/scripts/test-purge-agent-memories.ts",
    "test:dev": "tsx src/scripts/test-dev.ts",
    "test:dev-task": "tsx src/scripts/test-dev-task.ts",
    "test:speech-policy": "tsx src/scripts/test-speech-policy.ts",
    "test:orchestrator": "tsx src/scripts/test-orchestrator.ts",
    "test:mcp": "tsx src/scripts/test-mcp.ts",
    "mcp:gmail-auth": "tsx src/scripts/mcp-gmail-auth.ts",
    "test:telegram": "tsx src/scripts/test-telegram.ts",
    "telegram:chat-id": "tsx src/scripts/telegram-chat-id.ts",
    "auth:gmail": "tsx src/scripts/gmail-auth.ts",
    "launchd:install": "bash scripts/launchd-install.sh",
    "launchd:uninstall": "bash scripts/launchd-uninstall.sh",
    "launchd:status": "bash scripts/launchd-status.sh",
    "launchd:relocate": "bash scripts/launchd-relocate.sh",
    "house:install": "npm install --prefix house",
    "house:dev": "npm run dev --prefix house",
    "house:build": "npm run build --prefix house",
    "house:start": "npm run start --prefix house -- --port 3000",
    "house:restart": "bash scripts/house-restart.sh",
    "face:agent": "bash scripts/face-agent.sh",
    "sag:refresh": "bash scripts/sag-refresh.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.19",
    "@linear/sdk": "^86.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.0.0",
    "croner": "^10.0.1",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0",
    "grammy": "^1.44.0",
    "livekit-server-sdk": "^2.13.0",
    "mem0ai": "^3.0.8",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
